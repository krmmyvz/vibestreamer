          <li>EPG progress bar in channel list</li>
          <li>Multiview stability improvements</li>
          <li>Codebase restructured into logical modules</li>
        </ul>
      </description>
    </release>
  </releases>

  <content_rating type="oars-1.1" />

  <supports>
